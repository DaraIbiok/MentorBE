# ── Server ────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── MySQL Database ─────────────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/mentorme

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret        # Settings → API → JWT Settings in Supabase

# ── File uploads (local by default; switch to S3 by filling values below) ─────
UPLOAD_PROVIDER=local                      # "local" or "s3"
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=5242880                   # 5 MB

# AWS S3 (only needed when UPLOAD_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1

# ── Video rooms (Daily.co) ─────────────────────────────────────────────────────
DAILY_API_KEY=                             # https://dashboard.daily.co → Developers → API keys
DAILY_API_URL=https://api.daily.co/v1
